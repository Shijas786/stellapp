datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String   @id @default(uuid())
  chatId         String   @unique // WhatsApp phone number, e.g. "919876543210@c.us"
  username       String?  @unique // Custom federated username, e.g. "bob"
  stellarPublic  String   @unique
  stellarSecret  String   // AES-256-GCM encrypted
  evmAddress     String   @unique
  evmPrivateKey  String   // AES-256-GCM encrypted
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  onboarded      Boolean  @default(false)
  contacts       Contact[]
  deposits       PrivacyDeposit[]
}

model Contact {
  id          String   @id @default(uuid())
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name        String
  phoneNumber String
  createdAt   DateTime @default(now())

  @@unique([ownerId, name])
}

// Stores ZK Privacy Pool deposit commitments for Merkle proof reconstruction on withdrawal
model PrivacyDeposit {
  id            String   @id @default(uuid())
  ownerId       String
  owner         User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  contractId    String   // Stellar privacy pool contract ID
  commitmentHex String   // The on-chain commitment hash (hex)
  leafIndex     Int      @default(0) // Position in the Merkle tree (0-based)
  amount        String   // Amount of USDC deposited
  nullifierHash String?  // Set after withdrawal to prevent double-spend tracking
  spent         Boolean  @default(false)
  createdAt     DateTime @default(now())
}
